{
  "manifest_version": 3,
  "name": "BiliBrain",
  "version": "2.0.0",
  "description": "B站视频内容捕获与知识沉淀 — 字幕提取、AI讨论、保存到外脑",

  "permissions": [
    "tabs",
    "activeTab",
    "storage",
    "scripting",
    "cookies"
  ],

  "host_permissions": [
    "<all_urls>",
    "http://127.0.0.1:5577/*",
    "http://localhost:5577/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "BiliBrain",
    "default_icon": {
      "128": "icons/icon128.png"
    }
  },

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+K"
      }
    }
  }
}
